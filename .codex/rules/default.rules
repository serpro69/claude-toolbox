# Ported from .claude/settings.json permissions.deny (Bash entries only).
# Read(...) entries are enforced by the PreToolUse hook and SessionStart advisory.

prefix_rule(
    pattern = ["rm"],
    decision = "forbidden",
    justification = "Destructive file removal is blocked. Request explicit user approval before deleting files.",
    match = ["rm -rf /tmp/test", "rm foo.txt", "rm -r ./build"],
    not_match = ["ls -la", "mkdir -p dir", "grep -r pattern"],
)
